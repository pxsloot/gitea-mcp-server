# Gitea/Forgejo server configuration
GITEA_URL=https://git.home.lan
GITEA_TOKEN=your_api_token_here
GITEA_VERIFY_SSL=true
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional: HTTP transport (default: stdio)
# Use TRANSPORT_TYPE=http to run as HTTP server instead of stdio
# TRANSPORT_TYPE=http
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080
# HTTP_PATH=/mcp
# HTTP_CORS=  # defaults to GITEA_URL origin; set to '*' to allow all (dev only)
