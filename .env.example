# Gitea/Forgejo server configuration
GITEA_URL=https://git.home.lan
GITEA_TOKEN=your_api_token_here
GITEA_VERIFY_SSL=true
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Optional: Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Transport configuration (default: stdio)
#TRANSPORT_TYPE=stdio  # Use "streamable-http" for HTTP transport
#HOST=127.0.0.1        # Host to bind HTTP server to
#PORT=8080             # Port for HTTP transport
#HTTP_PATH=/mcp        # Path for MCP endpoint
#STATELESS_HTTP=false  # Use stateless HTTP mode
#JSON_RESPONSE=null    # Force JSON response (true/false/null for auto)
#CORS_ORIGINS=         # Comma-separated CORS origins (auto-derived from GITEA_URL if not set)
